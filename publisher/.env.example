# GHL Publisher — per-client Private Integration Tokens.
# Each client gets one line: GHL_PIT_<UPPERCASE_SLUG>=<token>
# Slug matches the filename in clients/<slug>.toml (lowercased, hyphens → underscores for the env var).
#
# Example:
#   clients/sam-trabulsi.toml  →  GHL_PIT_SAM_TRABULSI=pit-xxxxxxxx
#
# Tokens are NEVER committed. Add .env to .gitignore.

GHL_PIT_SAM_TRABULSI=
