# Brand Victory Dashboard — secrets template.
#
# 1. Copy this file to `.env`  (cp .env.example .env)
# 2. Paste your real tokens into .env on the lines below.
# 3. NEVER commit .env — it is git-ignored. Never paste a token into chat.

# Apify API token — get it from Apify → Settings → Integrations → API.
# Powers the "Refresh Instagram" button (Phase 4).
APIFY_TOKEN=

# Anthropic API key — get it from console.anthropic.com.
# Powers the "Generate Script for IG" button (Phase 5).
# (If you leave this blank, the server falls back to the local `claude` CLI if installed.)
ANTHROPIC_API_KEY=

# Optional overrides
# PORT=4000
# ANTHROPIC_MODEL=claude-sonnet-4-6
